{
  "name": "@pk-auth/passkeys-browser",
  "version": "1.3.0",
  "description": "pk-auth browser SDK: WebAuthn ceremonies + admin operations against the pk-auth wire contract.",
  "license": "MIT",
  "author": "Ned Wolpert",
  "homepage": "https://github.com/codeheadsystems/pk-auth/tree/main/clients/passkeys-browser#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeheadsystems/pk-auth.git",
    "directory": "clients/passkeys-browser"
  },
  "bugs": {
    "url": "https://github.com/codeheadsystems/pk-auth/issues"
  },
  "keywords": [
    "webauthn",
    "passkeys",
    "passkey",
    "authentication",
    "fido2",
    "pk-auth",
    "sdk"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  }
}
